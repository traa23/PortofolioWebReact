{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "checkJs": false
    },
    "include": [
        "src/**/*",
        "vite.config.js"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}